{
  "name": "@defrag/chatgpt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx server/src/index.ts",
    "start": "tsx server/src/index.ts",
    "build:web": "tsx web/src/index.ts",
    "build:server": "mkdir -p dist/server && esbuild server/src/app.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/server/app.js",
    "build": "pnpm build:web && pnpm build:server && pnpm typecheck",
    "vercel-build": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate:tools": "tsx server/src/harness/run-tool-harness.ts",
    "check:preview": "tsx server/src/harness/check-preview-setup.ts",
    "smoke:preview": "tsx server/src/harness/smoke-preview.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^0.4.0",
    "@modelcontextprotocol/sdk": "^1.18.0",
    "@supabase/supabase-js": "^2.100.0",
    "execa": "^9.6.0",
    "jose": "^6.2.2",
    "serverless-http": "^3.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "esbuild": "^0.25.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
