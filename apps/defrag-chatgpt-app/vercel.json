{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": false,
  "functions": {
    "api/[[...route]].ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/mcp",
      "destination": "/api/mcp"
    },
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/ready",
      "destination": "/api/ready"
    },
    {
      "source": "/.well-known/oauth-protected-resource/mcp",
      "destination": "/api/.well-known/oauth-protected-resource/mcp"
    }
  ]
}
