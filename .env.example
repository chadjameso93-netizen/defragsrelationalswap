# Reference env contract for DEFRAG.
# Local development should use apps/web/.env.local.
# Vercel Preview and Production should set the same canonical variables in the dashboard.

# App origin used in Stripe success/cancel/return URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Optional cross-project reference to the dedicated MCP host.
DEFRAG_MCP_APP_URL=https://mcp.defrag.app

# Supabase auth + DB access.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe checkout + portal.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PRICE_CORE=price_xxx
STRIPE_PRICE_STUDIO=price_xxx
STRIPE_PRICE_REALTIME=price_xxx

# Stripe webhook processing.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Optional provider-backed reasoning for Insight Studio.
DEFRAG_REASONING_PROVIDER=heuristic
OPENAI_API_KEY=
DEFRAG_OPENAI_MODEL=gpt-4.1-mini

# Legacy compatibility flag. Prefer DEFRAG_REASONING_PROVIDER.
DEFRAG_ENABLE_MODEL_GENERATION=false

# Future placeholders, not required for the canonical app today.
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_API=
STRIPE_PRICE_ENTERPRISE=
