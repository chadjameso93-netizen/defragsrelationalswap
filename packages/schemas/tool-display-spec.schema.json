{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "defrag.tool-display-spec.schema.json",
  "title": "ToolDisplaySpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "defaultMode",
    "capability",
    "inlineCardSufficient",
    "fullscreenJustifiedLater",
    "maxInlineCtas",
    "inlineFields",
    "omitFromInline"
  ],
  "properties": {
    "defaultMode": {
      "type": "string",
      "enum": ["inline-card", "inline-carousel", "fullscreen", "redirect-only"]
    },
    "capability": {
      "type": "string",
      "enum": ["inline-only", "inline-plus-fullscreen", "redirect-only"]
    },
    "inlineCardSufficient": { "type": "boolean" },
    "fullscreenJustifiedLater": { "type": "boolean" },
    "maxInlineCtas": { "type": "number" },
    "inlineFields": {
      "type": "array",
      "items": { "type": "string" }
    },
    "omitFromInline": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
