{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "defrag.billing-handoff.schema.json",
  "title": "BillingHandoffResponses",
  "type": "object",
  "oneOf": [
    {
      "additionalProperties": false,
      "required": ["checkoutUrl", "sessionId", "metadata"],
      "properties": {
        "checkoutUrl": { "type": "string", "format": "uri" },
        "sessionId": { "type": "string" },
        "metadata": { "$ref": "defrag.tool-response-metadata.schema.json" }
      }
    },
    {
      "additionalProperties": false,
      "required": ["portalUrl", "metadata"],
      "properties": {
        "portalUrl": { "type": "string", "format": "uri" },
        "metadata": { "$ref": "defrag.tool-response-metadata.schema.json" }
      }
    }
  ]
}
