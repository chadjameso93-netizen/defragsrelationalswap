{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "defrag.tool-response-metadata.schema.json",
  "title": "ToolResponseMetadata",
  "type": "object",
  "additionalProperties": false,
  "required": ["toolName", "structuredContent", "primaryMode", "supportsFullscreen", "websiteBacklink"],
  "properties": {
    "toolName": { "type": "string" },
    "structuredContent": { "type": "boolean" },
    "primaryMode": { "type": "string", "enum": ["inline-card", "inline-carousel", "fullscreen", "website-redirect-only"] },
    "supportsFullscreen": { "type": "boolean" },
    "websiteBacklink": { "type": ["string", "null"] }
  }
}
